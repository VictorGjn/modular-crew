{
  "name": "modular-crew",
  "version": "0.1.0",
  "description": "Declarative agent teams with DAG execution and context routing. Define what each agent knows.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "crew": "dist/bin/crew.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./context": {
      "import": "./dist/context/index.js",
      "types": "./dist/context/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "crew": "tsx bin/crew.ts"
  },
  "dependencies": {
    "inngest": "^3.0.0",
    "better-sqlite3": "^11.0.0",
    "zod": "^3.23.0",
    "yaml": "^2.4.0",
    "expr-eval": "^2.0.2",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "ulid": "^2.3.0",
    "eventsource-parser": "^2.0.0",
    "gpt-tokenizer": "^2.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "tsx": "^4.0.0",
    "vitest": "^2.0.0",
    "eslint": "^9.0.0"
  },
  "keywords": [
    "ai-agents",
    "multi-agent",
    "orchestration",
    "context-routing",
    "depth-packing",
    "declarative",
    "yaml",
    "llm",
    "inngest"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
